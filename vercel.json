{
  "version": 2,
  "builds": [
    {
      "src": "fashion_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    },
    {
      "src": "static/",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "fashion_project/wsgi.py"
    }
  ],
  "env": {
    "PYTHONPATH": "$PYTHONPATH:fashion_project"
  }
}
